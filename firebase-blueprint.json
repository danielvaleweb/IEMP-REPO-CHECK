{
  "entities": {
    "Playlist": {
      "title": "Playlist",
      "description": "Playlists criadas pelos membros",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "coverImage": { "type": "string" },
        "tracks": { 
          "type": "array",
          "items": { "type": "object", "properties": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "videoId": { "type": "string" },
            "thumbnail": { "type": "string" },
            "type": { "type": "string", "enum": ["normal", "vignette"] }
          }}
        },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "authorId", "tracks"]
    },
    "Post": {
      "title": "Post",
      "description": "Artigos e notícias da igreja",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "authorId"]
    },
    "Member": {
      "title": "Member",
      "description": "Membros da equipe e usuários do painel",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "editor", "member"] },
        "photoURL": { "type": "string" },
        "hasDashboardAccess": { "type": "boolean" },
        "pushToken": { "type": "string", "description": "Token do Expo para notificações push" }
      },
      "required": ["name", "email", "role"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Avisos e notificações disparadas pelo administrador",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time", "description": "Data/Hora para envio (se agendado)" },
        "sentAt": { "type": "string", "format": "date-time", "description": "Data/Hora em que foi enviado" },
        "status": { "type": "string", "enum": ["pending", "sent", "failed"] },
        "target": { "type": "string", "enum": ["all", "specific"], "description": "Público alvo" },
        "userIds": { "type": "array", "items": { "type": "string" }, "description": "IDs dos usuários específicos" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "status", "createdAt"]
    },
    "Agenda": {
      "title": "Agenda",
      "description": "Eventos e compromissos da igreja",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["title", "date"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Alertas do sistema (comentários, etc)",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "read"]
    },
    "Vignette": {
      "title": "Vignette",
      "description": "Vinhetas e jingles da rádio",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "videoId": { "type": "string" },
        "thumbnail": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "videoId"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Configurações gerais do site",
      "type": "object",
      "properties": {
        "enableHeaderVideos": { "type": "boolean" }
      }
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Registro de ações realizadas no dashboard",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "target": { "type": "string" },
        "details": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["action", "target", "userId", "timestamp"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "Notícias e reportagens do blog",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "content": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "imageCaption": { "type": "string" },
        "source": { "type": "string" },
        "videoUrl": { "type": "string" },
        "gallery": { "type": "string" },
        "organization": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Coleção de artigos"
    },
    "/blog/{blogId}": {
      "schema": "BlogPost",
      "description": "Notícias do blog"
    },
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Equipe e permissões"
    },
    "/agenda/{eventId}": {
      "schema": "Agenda",
      "description": "Eventos da igreja"
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "Alertas administrativos"
    },
    "/playlists/{playlistId}": {
      "schema": "Playlist",
      "description": "Playlists musicais dos membros"
    },
    "/vignettes/{vignetteId}": {
      "schema": "Vignette",
      "description": "Coleção de vinhetas da rádio"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Avisos e notificações disparadas pelo administrador"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Configurações globais"
    },
    "/audit-logs/{logId}": {
      "schema": "AuditLog",
      "description": "Logs de auditoria do dashboard"
    }
  }
}
